{
  "name": "@stem-brain/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "build": "pnpm run build:ios && pnpm run build:android",
    "build:ios": "expo export --platform ios --output-dir dist/ios --no-bytecode",
    "build:android": "expo export --platform android --output-dir dist/android --no-bytecode",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@stem-brain/graph-engine": "workspace:*",
    "@stem-brain/shared": "workspace:*",
    "expo": "~53.0.0",
    "expo-router": "~5.0.0",
    "expo-status-bar": "~2.2.0",
    "react": "19.0.0",
    "react-native": "0.79.2"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@types/react": "^19",
    "typescript": "^5"
  }
}
