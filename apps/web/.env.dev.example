# Development Environment Template
# Copy to .env.local for local development:
#   cp .env.dev.example .env.local

# App
APP_BASE_URL=http://localhost:3000

# Clerk (use test keys in dev; do not use live keys locally)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk routes
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/practice
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/practice

# Database (optional in dev; app falls back to in-memory mode when missing)
DATABASE_URL=postgres://user:password@host/dev_db?sslmode=require

# Optional: caps how many graph-derived knowledge cards are generated.
# Default 600. Set 1000+ if you expand GRAPH_NODES and want more cards.
KNOWLEDGE_CARD_LIMIT=600

# Optional: total seeded/practice card pool size (includes hidden drill cards).
# Default 1000. Increase if you add more content sources.
CARD_POOL_SIZE=1000

# Cloudflare deploy credentials (optional for local-only dev)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
