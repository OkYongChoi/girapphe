{
  "name": "stem-brain",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "pnpm --filter @stem-brain/web build",
    "build:web": "pnpm --filter @stem-brain/web build",
    "build:all": "turbo build",
    "build:cf": "pnpm --filter @stem-brain/web build:cf",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "check": "turbo check",
    "smoke": "pnpm --filter @stem-brain/web smoke",
    "harness": "pnpm harness:local",
    "harness:local": "pnpm lint && pnpm typecheck && pnpm --filter @stem-brain/web build && pnpm --filter @stem-brain/mobile typecheck",
    "harness:ci": "pnpm install --frozen-lockfile && pnpm harness:local",
    "harness:deploy": "pnpm build:cf",
    "deploy:cf": "pnpm --filter @stem-brain/web deploy:cf",
    "deploy:cf:dev": "pnpm --filter @stem-brain/web deploy:cf:dev",
    "deploy:cf:prod": "pnpm --filter @stem-brain/web deploy:cf:prod"
  },
  "devDependencies": {
    "turbo": "^2.5.4"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.4"
}
